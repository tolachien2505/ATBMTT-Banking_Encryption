{
  "name": "cyberbank-security-game-v2",
  "version": "2.0.0",
  "description": "Cyberpunk Hacker HUD Security Operations Game",
  "main": "dist/backend/server.js",
  "scripts": {
    "init:db": "ts-node src/backend/config/db-setup.ts",
    "backend:dev": "nodemon --watch src/backend --exec ts-node src/backend/server.ts",
    "frontend:dev": "npm run --prefix src/frontend dev",
    "frontend:build": "npm run --prefix src/frontend build",
    "build": "npm run frontend:build && tsc -p tsconfig.backend.json",
    "start": "node dist/backend/server.js",
    "dev": "concurrently \"npm run backend:dev\" \"npm run frontend:dev\""
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "mysql2": "^3.9.8",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.12.12",
    "concurrently": "^8.2.2",
    "nodemon": "^3.1.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  }
}
